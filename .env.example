# Optional local overrides for development
# Copy to `.env` if you want to customize your local paths.

# Production defaults:
# DATABASE_URL=sqlite:///C:/Users/<you>/RerootedData/data/prod/rerooted.db
# UPLOAD_DIR=C:/Users/<you>/RerootedData/uploads/prod

# Optional dedicated test storage:
# TEST_DATABASE_URL=sqlite:///C:/Users/<you>/RerootedData/data/test/rerooted.test.db
# TEST_UPLOAD_DIR=C:/Users/<you>/RerootedData/uploads/test
